# --- Required for AI-assisted event classification ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# --- Required for web scraping ---
BRAVE_SEARCH_API_KEY=

# --- Database ---
# Local development: SQLite (default, no setup needed)
DATABASE_URL=sqlite:///./citron.db
# Vercel / production: set this to a hosted Postgres URL to avoid ephemeral data loss
# DATABASE_URL=postgresql://user:password@host/dbname

# --- Personalisation ---
USER_REGION=Ontario, Canada
APP_NAME=Citron
